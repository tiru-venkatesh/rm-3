PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# MongoDB Atlas (free tier)
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/realmind

# Groq API - free at console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Blender - set your actual path
# Windows example:
BLENDER_PATH=C:\Program Files\Blender Foundation\Blender 5.1\blender.exe
# Linux/Mac example:
# BLENDER_PATH=/usr/bin/blender

SCRIPTS_DIR=./output/scripts
MESHES_DIR=./output/meshes
RENDERS_DIR=./output/renders

# Firebase Admin SDK
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
